---
import MainLayout from '@/layouts/main-layout.astro'
import PageHero from '@/components/shared/page-hero.astro'
import { getCollection } from 'astro:content'
import { Icon } from 'astro-icon/components'

const certificates = await getCollection('certificates')
---

<MainLayout title="Capacidade Técnica" description="Atestados de Capacidade Técnica da Oliver Cossmet.">
  <PageHero title="Capacidade Técnica" breadcrumb={[{ label: 'Capacidade Técnica', href: '/capacidade-tecnica' }]} />

  <section class="py-28 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="mx-auto mb-16 max-w-lg text-center text-[1.05rem] text-text-muted animate-on-scroll">
        Atestados que comprovam a qualidade e excelência dos serviços prestados a instituições em todo o Brasil.
      </p>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {certificates.map((cert, i) => (
          <div class:list={['animate-on-scroll group rounded-2xl border border-border/60 bg-white p-7 transition-all duration-500 hover:shadow-lg hover:shadow-primary/5 hover:border-primary/15', `stagger-${(i % 6) + 1}`]}>
            <div class="mb-5 flex h-11 w-11 items-center justify-center rounded-xl bg-primary-50 text-text-light transition-all duration-500 group-hover:bg-primary group-hover:text-white">
              <Icon name="lucide:file-badge" class="h-5 w-5" />
            </div>
            <h3 class="mb-2 text-[0.95rem] font-bold leading-snug tracking-tight text-text font-display">
              {cert.data.title}
            </h3>
            <div class="flex items-center gap-2 text-[12px] text-text-light">
              <span class="rounded-md bg-primary-50 px-2 py-0.5 font-medium text-text-muted">
                {cert.data.entity}
              </span>
              <span>{cert.data.state}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
