---
import MainLayout from '@/layouts/main-layout.astro'
import PageHero from '@/components/shared/page-hero.astro'
import { getCollection } from 'astro:content'

const certs = await getCollection('certificates')
---

<MainLayout title="Capacidade Técnica" description="Atestados de capacidade técnica da Oliver Cossmet em todo o Brasil.">
  <PageHero
    title="Capacidade Técnica"
    subtitle="Atestados e certidões que comprovam nossa experiência nacional."
    breadcrumb={[{ label: 'Capacidade Técnica' }]}
  />

  <section class="bg-white py-20 lg:py-28">
    <div class="mx-auto max-w-7xl px-6 lg:px-10">
      <div class="mb-10 flex items-center justify-between">
        <p class="text-sm text-ink-muted">
          <span class="font-semibold text-primary-dark">{certs.length}</span> documentos disponíveis
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {
          certs.map((cert) => (
            <div class="group flex flex-col rounded-2xl border border-surface-2 bg-surface p-6 transition-all hover:border-primary-muted hover:shadow-md">
              <div class="mb-4 flex items-start justify-between gap-3">
                <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-primary-pale">
                  <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                    <path d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                  </svg>
                </div>
                <span class="rounded-md bg-primary-pale px-2 py-0.5 text-xs font-semibold text-primary">
                  {cert.data.state}
                </span>
              </div>

              <h3 class="font-display mb-1 text-sm text-ink leading-snug flex-1">{cert.data.title}</h3>
              <p class="mt-1 text-xs text-ink-faint">{cert.data.entity}</p>

              <a
                href={cert.data.pdfUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-5 flex items-center gap-2 text-xs font-semibold text-primary-light transition-colors hover:text-primary"
              >
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                </svg>
                Baixar PDF
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</MainLayout>
