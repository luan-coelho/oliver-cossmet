---
import MainLayout from '@/layouts/main-layout.astro'
import PageHero from '@/components/shared/page-hero.astro'
import { getCollection } from 'astro:content'

const services = await getCollection('services')
const trainings = await getCollection('trainings')
const exams = await getCollection('exams')

const mainServices = services.filter((s) =>
  ['seguranca-do-trabalho', 'higiene-ocupacional', 'meio-ambiente', 'avaliacao-periodica'].includes(s.data.id),
)

const anchors = [
  { id: 'seguranca-do-trabalho', label: 'Segurança do Trabalho' },
  { id: 'higiene-ocupacional', label: 'Higiene Ocupacional' },
  { id: 'meio-ambiente', label: 'Meio Ambiente' },
  { id: 'avaliacao-periodica', label: 'Av. Periódica' },
  { id: 'treinamentos', label: 'Treinamentos' },
  { id: 'exames', label: 'Exames' },
]
---

<MainLayout title="Serviços" description="Conheça todos os serviços de saúde e segurança ocupacional da Oliver Cossmet.">
  <PageHero
    title="Nossos Serviços"
    subtitle="Soluções completas em saúde e segurança do trabalho para sua empresa."
    breadcrumb={[{ label: 'Serviços' }]}
  />

  <nav class="sticky top-[72px] z-30 border-b border-surface-2 bg-white/95 backdrop-blur-sm">
    <div class="mx-auto max-w-7xl px-6 lg:px-10">
      <div class="flex gap-0 overflow-x-auto scrollbar-hide">
        {
          anchors.map((a) => (
            <a
              href={`#${a.id}`}
              class="shrink-0 border-b-2 border-transparent px-4 py-4 text-sm font-medium text-ink-muted whitespace-nowrap transition-colors hover:text-primary"
            >
              {a.label}
            </a>
          ))
        }
      </div>
    </div>
  </nav>

  <div class="bg-white">
    {
      mainServices.map((service, si) => (
        <section
          id={service.data.id}
          class:list={['py-16 lg:py-20', si % 2 !== 0 && 'bg-surface']}
        >
          <div class="mx-auto max-w-7xl px-6 lg:px-10">
            <div class="mb-10">
              <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-primary-light">
                Serviço
              </p>
              <h2 class="font-display text-3xl text-primary-dark md:text-4xl">
                {service.data.title}
              </h2>
              <p class="mt-3 max-w-2xl text-base leading-relaxed text-ink-muted">
                {service.data.description}
              </p>
            </div>
            {service.data.items.length > 0 && (
              <div class="grid gap-4 md:grid-cols-2">
                {service.data.items.map((item) => (
                  <details class="group rounded-xl border border-surface-2 bg-white open:border-primary-muted open:shadow-sm">
                    <summary class="flex cursor-pointer list-none items-center justify-between gap-4 p-5">
                      <div class="flex items-center gap-3">
                        <div class="flex h-7 w-7 shrink-0 items-center justify-center rounded-lg bg-primary-pale">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                            <path d="M5 13l4 4L19 7"/>
                          </svg>
                        </div>
                        <span class="font-medium text-ink text-sm">{item.title}</span>
                      </div>
                      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-ink-faint transition-transform group-open:rotate-180">
                        <path d="M19 9l-7 7-7-7"/>
                      </svg>
                    </summary>
                    <div class="px-5 pb-5">
                      {item.details && (
                        <p class="mb-2 text-xs font-medium text-primary-light">{item.details}</p>
                      )}
                      <p class="text-sm leading-relaxed text-ink-muted">{item.description}</p>
                    </div>
                  </details>
                ))}
              </div>
            )}
          </div>
        </section>
      ))
    }

    <section id="treinamentos" class="py-16 lg:py-20">
      <div class="mx-auto max-w-7xl px-6 lg:px-10">
        <div class="mb-10">
          <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-primary-light">Capacitação</p>
          <h2 class="font-display text-3xl text-primary-dark md:text-4xl">Treinamentos</h2>
          <p class="mt-3 max-w-2xl text-base leading-relaxed text-ink-muted">
            Programas de treinamento conforme as Normas Regulamentadoras do Ministério do Trabalho.
          </p>
        </div>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {
            trainings.map((t) => (
              <div class="rounded-xl border border-surface-2 bg-surface p-5">
                <span class="mb-2 inline-block rounded-md bg-primary-pale px-2.5 py-1 text-xs font-bold text-primary">
                  {t.data.nr}
                </span>
                <h3 class="font-display mb-1.5 text-base text-ink">{t.data.title}</h3>
                <p class="text-xs leading-relaxed text-ink-muted">{t.data.details}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <section id="exames" class="bg-surface py-16 lg:py-20">
      <div class="mx-auto max-w-7xl px-6 lg:px-10">
        <div class="mb-10">
          <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-primary-light">Diagnóstico</p>
          <h2 class="font-display text-3xl text-primary-dark md:text-4xl">Exames</h2>
          <p class="mt-3 max-w-2xl text-base leading-relaxed text-ink-muted">
            Realizamos exames de saúde ocupacional com clínicas e laboratórios credenciados em todo o Brasil.
          </p>
        </div>
        <div class="grid gap-5 md:grid-cols-2 lg:grid-cols-4">
          {
            exams.map((e) => (
              <div class="rounded-xl border border-white bg-white p-6 shadow-sm">
                <div class="mb-3 flex h-10 w-10 items-center justify-center rounded-xl bg-primary-pale">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-primary">
                    <path d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2M9 12l2 2 4-4"/>
                  </svg>
                </div>
                <h3 class="font-display mb-2 text-base text-ink">{e.data.title}</h3>
                <p class="text-xs leading-relaxed text-ink-muted">{e.data.description}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </div>
</MainLayout>
