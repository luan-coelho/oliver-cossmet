---
import MainLayout from '@/layouts/main-layout.astro'
import PageHero from '@/components/shared/page-hero.astro'
import { Icon } from 'astro-icon/components'
---

<MainLayout title="Institucional" description="Conheça a história, missão, visão e valores da Oliver Cossmet.">
  <PageHero title="Institucional" breadcrumb={[{ label: 'Institucional', href: '/institucional' }]} />

  <section class="py-20 bg-white sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-16 lg:grid-cols-12">
        <div class="lg:col-span-7">
          <span class="text-[11px] font-semibold uppercase tracking-[0.2em] text-primary animate-on-scroll">Nossa História</span>
          <div class="mt-6 space-y-5 text-[1.05rem] leading-[1.9] text-text-muted">
            <p class="animate-on-scroll stagger-1">
              A Empresa <strong class="font-semibold text-text">OLIVER COSSMET</strong> é uma empresa de gestão de saúde e segurança ocupacional, que vem por meio de sua transparência dar prioridade na qualidade de vida de seus clientes, colaboradores, parceiros e amigos.
            </p>
            <p class="animate-on-scroll stagger-2">
              A Oliver Cossmet é um sonho que se tornou realidade através do esforço e dedicação do jovem Paulo Sergio Souza Oliveira. Vindo de família humilde aprendeu a dar valor em todos os conhecimentos adquiridos.
            </p>
            <p class="animate-on-scroll stagger-3">
              Através de seus estudos foi aprovado no Instituto Federal do Tocantins (IFTO) — Palmas — TO, no curso de Técnico em Segurança do Trabalho. Após a formação, decidiu iniciar seus trabalhos na área de gestão a saúde e segurança ocupacional, que iniciou suas atividades no ano de <strong class="font-semibold text-text">2012</strong>.
            </p>
            <p class="animate-on-scroll stagger-4">
              Oferece aos seus clientes uma consultoria em gestão a saúde e segurança ocupacional — desde a elaboração e coordenação dos programas previstos nas Normas Regulamentadoras.
            </p>
          </div>
        </div>

        <div class="lg:col-span-5 lg:pt-10">
          <div class="rounded-2xl border border-border bg-white p-8 shadow-sm animate-on-scroll">
            <h3 class="mb-6 text-sm font-semibold uppercase tracking-[0.15em] text-primary font-display">Linha do Tempo</h3>
            <div class="space-y-0">
              {[
                { year: '2012', text: 'Início das atividades em Palmas-TO' },
                { year: '2015', text: 'Expansão para outros estados' },
                { year: '2018', text: 'Mais de 50 clientes ativos' },
                { year: '2024', text: 'Atuação em 10+ estados' },
              ].map((item, i) => (
                <div class="flex items-baseline gap-4 border-b border-border/60 py-4 last:border-0">
                  <span class="text-xl font-extrabold text-primary font-display">{item.year}</span>
                  <span class="text-[0.875rem] text-text-muted">{item.text}</span>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>

      <div class="mt-20 grid gap-6 lg:grid-cols-3">
        {[
          {
            icon: 'lucide:eye',
            title: 'Visão',
            content: 'Ser referência nacional como empresa líder em seu segmento na realização de prestação de serviço oferecido.',
          },
          {
            icon: 'lucide:target',
            title: 'Missão',
            content: 'Atender as necessidades dos nossos clientes, colaboradores e parceiros. Encontrar soluções que levem as empresas à melhoria do desempenho em gestão de saúde e segurança ocupacional.',
          },
          {
            icon: 'lucide:gem',
            title: 'Valores',
            content: '',
          },
        ].map((card, i) => (
          <div class:list={['animate-on-scroll rounded-2xl border border-border bg-white p-8 shadow-sm', `stagger-${i + 1}`]}>
            <div class="mb-4 flex h-11 w-11 items-center justify-center rounded-xl bg-primary text-white">
              <Icon name={card.icon} class="h-5 w-5" aria-hidden="true" />
            </div>
            <h3 class="mb-3 text-xl font-extrabold tracking-tight text-text font-display">{card.title}</h3>
            {card.content ? (
              <p class="text-[0.9rem] leading-[1.8] text-text-muted">{card.content}</p>
            ) : (
              <ul class="space-y-2.5 text-[0.9rem] leading-[1.6] text-text-muted">
                <li><strong class="text-text">Excelência</strong> — Qualidade em serviços e atendimento</li>
                <li><strong class="text-text">Compromisso</strong> — Com clientes, colaboradores e parceiros</li>
                <li><strong class="text-text">Transparência</strong> — Integridade e honestidade nas relações</li>
                <li><strong class="text-text">Sentimento de Dono</strong> — Paixão e espírito empreendedor</li>
              </ul>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
