---
import MainLayout from '@/layouts/main-layout.astro'
import PageHero from '@/components/shared/page-hero.astro'
import { getCollection } from 'astro:content'
import { Icon } from 'astro-icon/components'

const credenciados = await getCollection('credenciados')
---

<MainLayout title="Credenciados" description="Nossa rede de clínicas e laboratórios credenciados em todo o Brasil.">
  <PageHero title="Credenciados" breadcrumb={[{ label: 'Credenciados', href: '/credenciados' }]} />

  <section class="py-28 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="mx-auto mb-16 max-w-lg text-center animate-on-scroll">
        <p class="text-[1.05rem] text-text-muted">
          Rede de parceiros entre clínicas e laboratórios de alta qualidade para atender demandas da gestão pública e privada em todo o Brasil.
        </p>
        <a
          href="https://wa.me/5563992147822?text=Olá! Gostaria de me credenciar como parceiro da Oliver Cossmet."
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-flex items-center gap-2.5 rounded-2xl bg-primary px-7 py-3.5 text-[13px] font-semibold text-white transition-all duration-300 hover:bg-primary hover:-translate-y-px hover:shadow-lg hover:shadow-primary/20"
        >
          <Icon name="lucide:handshake" class="h-4 w-4 text-accent" />
          Quero ser um credenciado
        </a>
      </div>

      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {credenciados.map((c, i) => (
          <div class:list={['animate-on-scroll flex items-center gap-4 rounded-2xl border border-border/60 bg-white p-5 transition-all duration-300 hover:shadow-md hover:border-accent/20', `stagger-${(i % 6) + 1}`]}>
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-accent-light text-[11px] font-bold tracking-wide text-accent-dark font-display">
              {c.data.name.substring(0, 2).toUpperCase()}
            </div>
            <div class="min-w-0">
              <div class="truncate text-[0.875rem] font-semibold text-text">{c.data.name}</div>
              <div class="flex items-center gap-1 text-[12px] text-text-light">
                <Icon name="lucide:map-pin" class="h-3 w-3" />
                {c.data.city}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
