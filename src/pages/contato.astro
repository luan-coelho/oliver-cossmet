---
import MainLayout from '@/layouts/main-layout.astro'
import PageHero from '@/components/shared/page-hero.astro'
import { CONTACT, SOCIAL } from '@/consts'
import { Icon } from 'astro-icon/components'

const whatsappUrl = `https://wa.me/${CONTACT.whatsapp}?text=${encodeURIComponent('Olá! Gostaria de mais informações sobre os serviços da Oliver Cossmet.')}`
---

<MainLayout title="Contato" description="Entre em contato com a Oliver Cossmet. Estamos em Palmas - Tocantins.">
  <PageHero title="Contato" breadcrumb={[{ label: 'Contato', href: '/contato' }]} />

  <section class="py-20 bg-white sm:py-28">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2">
        <div>
          <div class="animate-on-scroll">
            <h2 class="text-2xl font-extrabold tracking-tight text-text font-display sm:text-3xl">
              Fale Conosco
            </h2>
            <p class="mt-3 text-text-muted">
              Atendimento rápido e personalizado pelo WhatsApp ou pelos nossos canais abaixo.
            </p>
          </div>

          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-8 flex items-center gap-5 rounded-2xl bg-primary p-6 text-white transition-[transform,box-shadow] duration-300 hover:-translate-y-0.5 hover:shadow-lg hover:shadow-primary/20 animate-on-scroll stagger-1"
          >
            <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-white/20">
              <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <div class="text-lg font-bold font-display">WhatsApp</div>
              <div class="text-[0.875rem] text-white">{CONTACT.phone}</div>
            </div>
            <Icon name="lucide:arrow-right" class="ml-auto h-5 w-5 text-white/90" aria-hidden="true" />
          </a>

          <div class="mt-10 grid gap-6 sm:grid-cols-2">
            <div class="rounded-2xl border border-border bg-white p-6 animate-on-scroll stagger-2">
              <Icon name="lucide:map-pin" class="mb-3 h-5 w-5 text-primary" aria-hidden="true" />
              <h3 class="font-bold text-text font-display">Endereço</h3>
              <p class="mt-2 text-[0.85rem] leading-[1.7] text-text-muted">
                {CONTACT.address.street}<br />
                {CONTACT.address.neighborhood}<br />
                CEP: {CONTACT.address.cep}<br />
                {CONTACT.address.city} — {CONTACT.address.stateAbbr}
              </p>
            </div>

            <div class="rounded-2xl border border-border bg-white p-6 animate-on-scroll stagger-3">
              <Icon name="lucide:mail" class="mb-3 h-5 w-5 text-primary" aria-hidden="true" />
              <h3 class="font-bold text-text font-display">E-mail</h3>
              <a href={`mailto:${CONTACT.email}`} class="mt-2 inline-block text-[0.85rem] text-primary hover:underline">
                {CONTACT.email}
              </a>
            </div>

            <div class="rounded-2xl border border-border bg-white p-6 sm:col-span-2 animate-on-scroll stagger-4">
              <Icon name="lucide:share-2" class="mb-3 h-5 w-5 text-primary" aria-hidden="true" />
              <h3 class="font-bold text-text font-display">Redes Sociais</h3>
              <div class="mt-3 flex gap-2">
                {[
                  { href: SOCIAL.linkedin, icon: 'lucide:linkedin', label: 'LinkedIn' },
                  { href: SOCIAL.facebook, icon: 'lucide:facebook', label: 'Facebook' },
                  { href: SOCIAL.instagram, icon: 'lucide:instagram', label: 'Instagram' },
                ].map((s) => (
                  <a href={s.href} target="_blank" rel="noopener noreferrer" class="flex h-10 w-10 items-center justify-center rounded-xl border border-border text-text-muted transition-[border-color,background-color,color] duration-200 hover:border-primary hover:bg-primary hover:text-white" aria-label={s.label}>
                    <Icon name={s.icon} class="h-4 w-4" />
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>

        <div class="overflow-hidden rounded-2xl border border-border shadow-sm animate-on-scroll stagger-2">
          <iframe
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3927.7!2d-48.332!3d-10.208!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zMTDCsDEyJzI4LjgiUyA0OMKwMTknNTUuMiJX!5e0!3m2!1spt-BR!2sbr!4v1"
            width="100%"
            height="100%"
            style="border:0; min-height:500px;"
            allowfullscreen=""
            loading="lazy"
            referrerpolicy="no-referrer-when-downgrade"
            title="Localização Oliver Cossmet"
          ></iframe>
        </div>
      </div>
    </div>
  </section>
</MainLayout>
