---
import MainLayout from '@/layouts/main-layout.astro'
---

<MainLayout title="Página não encontrada">
  <div class="flex min-h-screen items-center justify-center bg-surface px-6">
    <div class="text-center">
      <div class="font-display mb-2 text-[8rem] leading-none text-primary-pale">404</div>
      <h1 class="font-display mb-4 text-3xl text-primary-dark">Página não encontrada</h1>
      <p class="mb-8 text-ink-muted">
        O endereço que você tentou acessar não existe ou foi movido.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 rounded-xl bg-primary px-7 py-3.5 font-semibold text-white transition-all hover:bg-primary-dark"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5M12 19l-7-7 7-7"/>
        </svg>
        Voltar ao início
      </a>
    </div>
  </div>
</MainLayout>
