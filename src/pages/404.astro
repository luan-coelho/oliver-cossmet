---
import BaseLayout from '@/layouts/base-layout.astro'
import { Icon } from 'astro-icon/components'
---

<BaseLayout title="Página não encontrada">
  <div class="grain relative flex min-h-screen flex-col items-center justify-center overflow-hidden bg-primary px-4 text-center">
    <div class="absolute inset-0 bg-gradient-to-br from-primary-dark via-primary to-primary-400 opacity-80"></div>

    <div class="relative">
      <div class="mb-8 text-[clamp(6rem,15vw,12rem)] leading-none font-extrabold tracking-[-0.05em] text-white/[0.06] font-display">
        404
      </div>
      <div class="-mt-16 mb-2 text-[11px] font-semibold uppercase tracking-[0.3em] text-accent">
        Página não encontrada
      </div>
      <p class="mb-10 text-white/90">
        O conteúdo que você procura não está disponível.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2.5 rounded-2xl bg-white px-7 py-3.5 text-[13px] font-bold text-primary transition-all duration-300 hover:-translate-y-px hover:shadow-xl"
      >
        <Icon name="lucide:arrow-left" class="h-4 w-4" />
        Voltar ao início
      </a>
    </div>
  </div>
</BaseLayout>
