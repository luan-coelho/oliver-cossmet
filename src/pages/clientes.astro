---
import MainLayout from '@/layouts/main-layout.astro'
import PageHero from '@/components/shared/page-hero.astro'
import { getCollection } from 'astro:content'
import { Icon } from 'astro-icon/components'

const clients = await getCollection('clients')
---

<MainLayout title="Clientes" description="Conheça as empresas e instituições que confiam na Oliver Cossmet.">
  <PageHero title="Nossos Clientes" breadcrumb={[{ label: 'Clientes', href: '/clientes' }]} />

  <section class="py-28 bg-white">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <p class="mx-auto mb-16 max-w-lg text-center text-[1.05rem] text-text-muted animate-on-scroll">
        Atendemos mais de 100 clientes em mais de 10 estados, incluindo órgãos públicos federais, estaduais e empresas privadas.
      </p>

      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {clients.map((client, i) => (
          <div class:list={['animate-on-scroll flex items-center gap-4 rounded-2xl border border-border/60 bg-white p-5 transition-all duration-300 hover:shadow-md hover:border-primary/15', `stagger-${(i % 6) + 1}`]}>
            <div class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl bg-primary text-[11px] font-bold tracking-wide text-white font-display">
              {client.data.name.substring(0, 2).toUpperCase()}
            </div>
            <div class="min-w-0">
              <div class="truncate text-[0.875rem] font-semibold text-text">{client.data.name}</div>
              <div class="flex items-center gap-1 text-[12px] text-text-light">
                <Icon name="lucide:map-pin" class="h-3 w-3" />
                {client.data.city}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</MainLayout>
