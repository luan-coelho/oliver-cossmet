---
import MainLayout from '@/layouts/main-layout.astro'
import Hero from '@/components/hero/hero.astro'
import ServiceCards from '@/components/home/service-cards.astro'
import SecondaryServices from '@/components/home/secondary-services.astro'
import ClientsCarousel from '@/components/home/clients-carousel.astro'
import { CONTACT_INFO } from '@/consts'

const whatsappMsg = encodeURIComponent('Olá! Gostaria de solicitar um orçamento.')
const whatsappHref = `https://wa.me/${CONTACT_INFO.whatsapp}?text=${whatsappMsg}`
---

<MainLayout>
  <Hero />
  <ServiceCards />
  <SecondaryServices />
  <ClientsCarousel />

  <section class="bg-primary-dark py-20">
    <div class="mx-auto max-w-7xl px-6 lg:px-10">
      <div class="flex flex-col items-center gap-6 text-center md:flex-row md:justify-between md:text-left">
        <div>
          <h2 class="font-display text-2xl text-white md:text-3xl">
            Pronto para garantir a segurança da sua equipe?
          </h2>
          <p class="mt-2 text-white/60">
            Entre em contato agora e solicite uma consultoria personalizada.
          </p>
        </div>
        <a
          href={whatsappHref}
          target="_blank"
          rel="noopener noreferrer"
          class="shrink-0 rounded-xl bg-accent px-8 py-4 font-semibold text-primary-dark transition-all hover:shadow-lg hover:shadow-accent/25"
        >
          Solicitar orçamento
        </a>
      </div>
    </div>
  </section>
</MainLayout>
