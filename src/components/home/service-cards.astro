---
import { Icon } from 'astro-icon/components'
import SectionTitle from '@/components/shared/section-title.astro'

const services = [
  {
    icon: 'lucide:shield-check',
    title: 'Segurança do Trabalho',
    description: 'Gestão de Medicina e Segurança para atender às Normas Regulamentadoras e eSOCIAL.',
    href: '/servicos#seguranca-do-trabalho',
    accent: 'bg-emerald-600',
    num: '01',
  },
  {
    icon: 'lucide:flask-conical',
    title: 'Higiene Ocupacional',
    description: 'Proteção da integridade física e mental do trabalhador contra riscos de saúde.',
    href: '/servicos#higiene-ocupacional',
    accent: 'bg-teal-600',
    num: '02',
  },
  {
    icon: 'lucide:leaf',
    title: 'Meio Ambiente',
    description: 'Análise e contingência ambiental com equipe multidisciplinar e tecnologia avançada.',
    href: '/servicos#meio-ambiente',
    accent: 'bg-green-700',
    num: '03',
  },
  {
    icon: 'lucide:stethoscope',
    title: 'Avaliação Periódica',
    description: 'Avaliações em todo o território Nacional via sistema SIAPENET.',
    href: '/servicos#avaliacao-periodica',
    accent: 'bg-lime-700',
    num: '04',
  },
]
---

<section class="relative overflow-hidden py-28 bg-white">
  <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-border to-transparent"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="animate-on-scroll">
      <SectionTitle
        title="Nossos Serviços"
        subtitle="Soluções completas em saúde e segurança ocupacional"
      />
    </div>

    <div class="mt-4 grid gap-6 md:grid-cols-2 lg:grid-cols-4">
      {services.map((service, i) => (
        <a
          href={service.href}
          class:list={[
            'animate-on-scroll group relative flex flex-col rounded-3xl border border-border/60 bg-white p-8 transition-[border-color,background-color,box-shadow,color,transform] duration-500 hover:border-primary/20 hover:bg-primary hover:shadow-[0_24px_64px] hover:shadow-primary/10 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2',
            `stagger-${i + 1}`,
          ]}
        >
          <span class="absolute top-6 right-6 text-[11px] font-mono tracking-wider text-text-light/40 transition-colors duration-500 group-hover:text-white/20">
            {service.num}
          </span>

          <div class:list={[
            'mb-6 flex h-12 w-12 items-center justify-center rounded-2xl text-white transition-all duration-500 group-hover:scale-110 group-hover:shadow-lg',
            service.accent
          ]}>
            <Icon name={service.icon} class="h-5 w-5" aria-hidden="true" />
          </div>

          <h3 class="mb-3 text-[1.15rem] font-bold leading-tight tracking-tight text-text font-display transition-colors duration-500 group-hover:text-white">
            {service.title}
          </h3>

          <p class="mb-6 flex-1 text-[0.875rem] leading-relaxed text-text-muted transition-colors duration-500 group-hover:text-white/50">
            {service.description}
          </p>

          <div class="flex items-center gap-1.5 text-[13px] font-medium text-primary transition-all duration-500 group-hover:text-accent">
            Saiba mais
            <Icon name="lucide:arrow-up-right" class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" />
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
