---
import { Icon } from 'astro-icon/components'

const items = [
  {
    icon: 'lucide:user-check',
    title: 'Avaliação Periódica',
    description: 'Avaliações em todo o território Nacional, através do sistema do Governo Federal SIAPENET.',
    href: '/servicos#avaliacao-periodica',
  },
  {
    icon: 'lucide:monitor-check',
    title: 'eSOCIAL',
    description: 'Integração e monitoramento do sistema de controle das informações sociais do Governo Federal.',
    href: '/servicos',
  },
  {
    icon: 'lucide:heart-pulse',
    title: 'Gestão de Saúde',
    description: 'Gestão Integrada de Riscos para a saúde com consultoria e assessoria profissional.',
    href: '/servicos',
  },
  {
    icon: 'lucide:handshake',
    title: 'Credenciados',
    description: 'Rede de clínicas e laboratórios parceiros de alta qualidade em todo o Brasil.',
    href: '/credenciados',
  },
]
---

<section class="py-28 bg-primary-50">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="mb-16 max-w-xl animate-on-scroll">
      <span class="mb-4 inline-block text-[11px] font-semibold uppercase tracking-[0.2em] text-primary">
        Como Atuamos
      </span>
      <h2 class="text-3xl font-extrabold tracking-tight text-text font-display text-balance sm:text-4xl">
        Cobertura nacional com equipe qualificada
      </h2>
      <div class="mt-4 h-0.5 w-12 bg-primary"></div>
    </div>

    <div class="grid gap-6 sm:grid-cols-2">
      {items.map((item, i) => (
        <a
          href={item.href}
          class:list={[
            'animate-on-scroll group flex gap-5 rounded-2xl border border-border/60 bg-white p-8 transition-[border-color,box-shadow,transform] duration-300 hover:border-primary/20 hover:shadow-lg hover:shadow-primary/5 hover:-translate-y-0.5 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2',
            `stagger-${i + 1}`,
          ]}
        >
          <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-primary text-white transition-transform duration-300 group-hover:scale-110">
            <Icon name={item.icon} class="h-5 w-5" aria-hidden="true" />
          </div>

          <div>
            <h3 class="text-lg font-bold tracking-tight text-text font-display">
              {item.title}
            </h3>
            <p class="mt-2 text-[0.9rem] leading-relaxed text-text-muted">
              {item.description}
            </p>
            <div class="mt-4 flex items-center gap-1.5 text-[13px] font-medium text-primary opacity-0 transition-opacity duration-300 group-hover:opacity-100">
              Saiba mais
              <Icon name="lucide:arrow-right" class="h-3.5 w-3.5 transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true" />
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>
