---
import { Icon } from 'astro-icon/components'
import { CONTACT } from '@/consts'

const whatsappUrl = `https://wa.me/${CONTACT.whatsapp}?text=${encodeURIComponent('Olá! Gostaria de mais informações sobre os serviços da Oliver Cossmet.')}`
---

<section class="relative overflow-hidden bg-white">
  <div class="absolute inset-0" aria-hidden="true">
    <div class="absolute top-0 right-0 h-[70%] w-[45%] bg-gradient-to-bl from-primary-50 via-primary-100/50 to-transparent"></div>
    <div class="absolute bottom-0 left-0 h-[40%] w-[30%] bg-gradient-to-tr from-primary-50 to-transparent"></div>
  </div>

  <div class="absolute inset-0 opacity-[0.025]" aria-hidden="true">
    <svg class="h-full w-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="crosses" x="0" y="0" width="80" height="80" patternUnits="userSpaceOnUse">
          <path d="M40 28v24M28 40h24" stroke="currentColor" stroke-width="1" fill="none" class="text-primary"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#crosses)"/>
    </svg>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-12 py-20 lg:grid-cols-2 lg:py-28">
      <div>
        <div class="mb-8 inline-flex w-fit items-center gap-2.5 rounded-full border border-primary/15 bg-primary-50 px-5 py-2.5 text-[13px] tracking-wide text-primary"
             style="animation: fade-up 0.6s var(--ease-out-expo) 0.1s both">
          <span class="h-1.5 w-1.5 rounded-full bg-primary animate-pulse"></span>
          Desde 2012 — Palmas, Tocantins
        </div>

        <h1 class="text-[clamp(2.5rem,5vw,4.5rem)] leading-[1] font-extrabold tracking-[-0.03em] text-text text-balance"
            style="animation: fade-up 0.8s var(--ease-out-expo) 0.2s both">
          Cuidando da<br/>
          <span class="text-primary">saúde e segurança</span><br/>
          ocupacional
        </h1>

        <p class="mt-8 max-w-lg text-[1.05rem] leading-[1.7] text-text-muted"
           style="animation: fade-up 0.8s var(--ease-out-expo) 0.35s both">
          Consultoria completa em saúde, segurança e medicina do trabalho — da elaboração dos programas das NRs à gestão integrada de riscos em todo o Brasil.
        </p>

        <div class="mt-10 flex flex-col gap-4 sm:flex-row sm:items-center"
             style="animation: fade-up 0.8s var(--ease-out-expo) 0.5s both">
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="group inline-flex items-center justify-center gap-3 rounded-2xl bg-primary px-8 py-4 text-[15px] font-semibold text-white shadow-[0_8px_32px] shadow-primary/25 transition-[transform,box-shadow] duration-300 hover:shadow-primary/40 hover:-translate-y-0.5 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
          >
            <svg class="h-5 w-5 transition-transform duration-300 group-hover:scale-110" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Fale Conosco
          </a>
          <a
            href="/servicos"
            class="group inline-flex items-center justify-center gap-2 rounded-2xl border border-border px-8 py-4 text-[15px] font-medium text-text-muted transition-[border-color,color] duration-300 hover:border-primary hover:text-primary focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
          >
            Nossos Serviços
            <Icon name="lucide:arrow-right" class="h-4 w-4 transition-transform duration-300 group-hover:translate-x-1" aria-hidden="true" />
          </a>
        </div>
      </div>

      <div class="hidden lg:block" style="animation: fade-up 1s var(--ease-out-expo) 0.4s both" aria-hidden="true">
        <div class="relative">
          <div class="absolute -top-8 -left-8 h-full w-full rounded-3xl bg-primary/5"></div>

          <div class="relative grid grid-cols-2 gap-4">
            <div class="space-y-4">
              <div class="rounded-2xl bg-primary p-6 text-white shadow-lg shadow-primary/20">
                <Icon name="lucide:shield-check" class="mb-3 h-8 w-8" />
                <div class="text-[15px] font-bold font-display">Segurança do Trabalho</div>
                <div class="mt-1 text-[13px] text-white/90">NRs e eSOCIAL</div>
              </div>

              <div class="rounded-2xl border border-border bg-white p-6 shadow-sm">
                <Icon name="lucide:leaf" class="mb-3 h-8 w-8 text-primary" />
                <div class="text-[15px] font-bold text-text font-display">Meio Ambiente</div>
                <div class="mt-1 text-[13px] text-text-muted">PGRS, PGRSS, PEA</div>
              </div>

              <div class="rounded-2xl bg-primary-50 p-6">
                <div class="text-3xl font-extrabold text-primary font-display">100+</div>
                <div class="mt-1 text-[13px] text-text-muted">Clientes em todo o Brasil</div>
              </div>
            </div>

            <div class="mt-12 space-y-4">
              <div class="rounded-2xl border border-border bg-white p-6 shadow-sm">
                <Icon name="lucide:flask-conical" class="mb-3 h-8 w-8 text-primary" />
                <div class="text-[15px] font-bold text-text font-display">Higiene Ocupacional</div>
                <div class="mt-1 text-[13px] text-text-muted">Riscos físicos, químicos e biológicos</div>
              </div>

              <div class="rounded-2xl bg-primary p-6 text-white shadow-lg shadow-primary/20">
                <Icon name="lucide:stethoscope" class="mb-3 h-8 w-8" />
                <div class="text-[15px] font-bold font-display">Avaliação Periódica</div>
                <div class="mt-1 text-[13px] text-white/90">Via SIAPENET</div>
              </div>

              <div class="rounded-2xl border border-border bg-white p-6 shadow-sm">
                <Icon name="lucide:graduation-cap" class="mb-3 h-8 w-8 text-primary" />
                <div class="text-[15px] font-bold text-text font-display">17 Treinamentos</div>
                <div class="mt-1 text-[13px] text-text-muted">NR 01 ao NR 25</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="relative bg-primary">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 gap-4 py-12 sm:py-14 md:grid-cols-4 md:gap-8">
      {[
        { value: '14+', label: 'Anos de experiência', icon: 'lucide:calendar-check' },
        { value: '100+', label: 'Clientes atendidos', icon: 'lucide:building-2' },
        { value: '10+', label: 'Estados de atuação', icon: 'lucide:map' },
        { value: '50+', label: 'Credenciados parceiros', icon: 'lucide:handshake' },
      ].map((stat) => (
        <div class="flex flex-col items-center text-center">
          <Icon name={stat.icon} class="mb-3 h-6 w-6 text-white/80" aria-hidden="true" />
          <div class="text-3xl font-extrabold tracking-tight text-white font-display sm:text-4xl">
            {stat.value}
          </div>
          <div class="mt-1 text-[13px] text-white/90">{stat.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
