---
interface Props {
  title: string
  breadcrumb?: { label: string; href: string }[]
}

const { title, breadcrumb } = Astro.props
---

<section class="bg-primary">
  <div class="mx-auto flex max-w-7xl items-center justify-between gap-4 px-4 py-10 sm:px-6 sm:py-12 lg:px-8">
    <h1 class="text-2xl font-extrabold tracking-[-0.01em] text-white font-display sm:text-3xl">
      {title}
    </h1>
    {breadcrumb && (
      <nav class="hidden items-center gap-1.5 text-[13px] sm:flex" aria-label="Breadcrumb">
        <a href="/" class="text-white/90 transition-colors hover:text-white">Home</a>
        {breadcrumb.map((item) => (
          <>
            <span class="text-white/70" aria-hidden="true">&rsaquo;</span>
            <span class="font-medium text-white">{item.label}</span>
          </>
        ))}
      </nav>
    )}
  </div>
</section>
