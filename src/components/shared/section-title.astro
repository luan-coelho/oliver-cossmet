---
interface Props {
  tag?: string
  title: string
  subtitle?: string
  align?: 'left' | 'center'
  light?: boolean
}

const { tag, title, subtitle, align = 'center', light = false } = Astro.props
---

<div class:list={['section-title', align === 'center' && 'text-center']}>
  {
    tag && (
      <p
        class:list={[
          'mb-3 text-xs font-semibold uppercase tracking-[0.2em]',
          light ? 'text-accent' : 'text-primary-light',
        ]}
      >
        {tag}
      </p>
    )
  }
  <h2
    class:list={[
      'font-display text-3xl leading-tight md:text-4xl lg:text-[2.6rem]',
      light ? 'text-white' : 'text-primary-dark',
    ]}
  >
    {title}
  </h2>
  {
    subtitle && (
      <p
        class:list={[
          'mx-auto mt-4 max-w-xl text-base leading-relaxed',
          align === 'center' && 'text-center',
          light ? 'text-white/65' : 'text-ink-muted',
        ]}
      >
        {subtitle}
      </p>
    )
  }
</div>
