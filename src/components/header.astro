---
import { NAV_LINKS, SITE_TITLE } from '@/consts'
import { Icon } from 'astro-icon/components'

const currentPath = Astro.url.pathname
---

<a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[60] focus:rounded-lg focus:bg-primary focus:px-4 focus:py-2 focus:text-white focus:shadow-lg">
  Pular para o conteúdo
</a>
<header class="sticky top-0 z-50 border-b border-border/60 bg-white">
  <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3.5 sm:px-6 lg:px-8">
    <a href="/" class="flex items-center">
      <img src="/logo.jpg" alt="Oliver Cossmet — Gestão de Saúde e Segurança Ocupacional" class="h-10 w-auto sm:h-12" width="280" height="56" />
    </a>

    <nav class="hidden items-center gap-0.5 lg:flex">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={[
            'rounded-lg px-3.5 py-2 text-[13px] font-medium tracking-[-0.01em] transition-colors duration-200 focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2',
            currentPath === link.href || currentPath.startsWith(link.href + '/')
              ? 'text-primary bg-primary-50 font-semibold'
              : 'text-text-muted hover:text-text hover:bg-gray-50',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://wa.me/5563992147822"
        target="_blank"
        rel="noopener noreferrer"
        class="ml-3 inline-flex items-center gap-2 rounded-xl bg-primary px-5 py-2.5 text-[13px] font-semibold text-white transition-[transform,box-shadow] duration-300 hover:shadow-lg hover:shadow-primary/20 hover:-translate-y-px focus-visible:ring-2 focus-visible:ring-primary focus-visible:ring-offset-2"
      >
        <Icon name="lucide:message-circle" class="h-3.5 w-3.5" aria-hidden="true" />
        WhatsApp
      </a>
    </nav>

    <button
      id="mobile-menu-btn"
      class="flex h-9 w-9 items-center justify-center rounded-lg text-text transition-colors hover:bg-gray-100 lg:hidden"
      aria-label="Abrir menu"
    >
      <Icon name="lucide:menu" class="h-5 w-5" id="menu-icon-open" />
      <Icon name="lucide:x" class="hidden h-5 w-5" id="menu-icon-close" />
    </button>
  </div>

  <div id="mobile-menu" class="hidden border-t border-border bg-white lg:hidden">
    <nav class="mx-auto max-w-7xl space-y-0.5 px-4 py-4">
      {NAV_LINKS.map((link) => (
        <a
          href={link.href}
          class:list={[
            'block rounded-xl px-4 py-3.5 text-[15px] font-medium transition-colors',
            currentPath === link.href
              ? 'bg-primary-50 text-primary font-semibold'
              : 'text-text-muted hover:bg-gray-50 hover:text-text',
          ]}
        >
          {link.label}
        </a>
      ))}
      <a
        href="https://wa.me/5563992147822"
        target="_blank"
        rel="noopener noreferrer"
        class="mt-2 flex items-center justify-center gap-2 rounded-xl bg-primary px-4 py-3.5 text-[15px] font-semibold text-white"
      >
        <Icon name="lucide:message-circle" class="h-4 w-4" aria-hidden="true" />
        WhatsApp
      </a>
    </nav>
  </div>
</header>

<script>
  const mobileBtn = document.getElementById('mobile-menu-btn')!
  const mobileMenu = document.getElementById('mobile-menu')!
  const iconOpen = document.getElementById('menu-icon-open')!
  const iconClose = document.getElementById('menu-icon-close')!

  mobileBtn.addEventListener('click', () => {
    const isOpen = !mobileMenu.classList.contains('hidden')
    mobileMenu.classList.toggle('hidden')
    iconOpen.classList.toggle('hidden')
    iconClose.classList.toggle('hidden')
    mobileBtn.setAttribute('aria-label', isOpen ? 'Abrir menu' : 'Fechar menu')
  })
</script>
