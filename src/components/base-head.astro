---
import { SITE_TITLE, SITE_DESCRIPTION, SITE_URL } from '@/consts'
import '@/styles/global.css'

interface Props {
  title?: string
  description?: string
  image?: string
}

const {
  title = SITE_TITLE,
  description = SITE_DESCRIPTION,
  image = '/og-image.jpg',
} = Astro.props

const canonicalURL = new URL(Astro.url.pathname, SITE_URL)
const pageTitle = title === SITE_TITLE ? title : `${title} — Oliver Cossmet`
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="canonical" href={canonicalURL} />

<title>{pageTitle}</title>
<meta name="description" content={description} />
<meta name="robots" content="index, follow" />

<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image, SITE_URL)} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(image, SITE_URL)} />

<script type="application/ld+json">
  {
    JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'LocalBusiness',
      name: 'Oliver Cossmet',
      description: SITE_DESCRIPTION,
      url: SITE_URL,
      telephone: '+55 63 99214-7822',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Quadra ARSO 111, Alameda 24, SN, Lote 03, QC 01, Sala 1',
        addressLocality: 'Palmas',
        addressRegion: 'TO',
        postalCode: '77019-056',
        addressCountry: 'BR',
      },
    })
  }
</script>
