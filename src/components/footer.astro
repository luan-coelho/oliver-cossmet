---
import { SITE_TITLE, CONTACT, SOCIAL, NAV_LINKS } from '@/consts'
import { Icon } from 'astro-icon/components'
---

<footer class="relative overflow-hidden bg-primary">
  <div class="absolute inset-0 bg-gradient-to-b from-black/5 to-transparent" aria-hidden="true"></div>

  <div class="relative mx-auto max-w-7xl px-4 pt-20 pb-10 sm:px-6 lg:px-8">
    <div class="grid gap-16 lg:grid-cols-12">
      <div class="lg:col-span-5">
        <div class="flex items-center gap-2.5">
          <div class="flex h-9 w-9 items-center justify-center rounded-lg bg-white">
            <svg class="h-4 w-4 text-primary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" aria-hidden="true">
              <path d="M12 4v16M4 12h16"/>
            </svg>
          </div>
          <span class="text-[15px] font-bold tracking-[-0.02em] text-white font-display">{SITE_TITLE}</span>
        </div>
        <p class="mt-5 max-w-sm text-[0.9rem] leading-[1.8] text-white">
          Empresa de gestão de saúde e segurança ocupacional que prioriza a qualidade de vida de seus clientes, colaboradores, parceiros e amigos desde 2012.
        </p>
        <div class="mt-6 flex gap-2">
          {[
            { href: SOCIAL.linkedin, icon: 'lucide:linkedin', label: 'LinkedIn' },
            { href: SOCIAL.facebook, icon: 'lucide:facebook', label: 'Facebook' },
            { href: SOCIAL.instagram, icon: 'lucide:instagram', label: 'Instagram' },
          ].map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/20 text-white transition-[background-color] duration-300 hover:bg-white/30 focus-visible:ring-2 focus-visible:ring-white focus-visible:ring-offset-2 focus-visible:ring-offset-primary"
              aria-label={s.label}
            >
              <Icon name={s.icon} class="h-4 w-4" />
            </a>
          ))}
        </div>
      </div>

      <div class="lg:col-span-3">
        <h3 class="text-[11px] font-semibold uppercase tracking-[0.2em] text-white">
          Navegação
        </h3>
        <nav class="mt-5 flex flex-col gap-1">
          {NAV_LINKS.map((link) => (
            <a
              href={link.href}
              class="rounded-md py-1.5 text-[0.875rem] text-white transition-opacity duration-300 opacity-90 hover:opacity-100"
            >
              {link.label}
            </a>
          ))}
        </nav>
      </div>

      <div class="lg:col-span-4">
        <h3 class="text-[11px] font-semibold uppercase tracking-[0.2em] text-white">
          Contato
        </h3>
        <div class="mt-5 space-y-4">
          <div class="flex items-start gap-3">
            <Icon name="lucide:map-pin" class="mt-1 h-4 w-4 shrink-0 text-white" />
            <p class="text-[0.875rem] leading-[1.8] text-white">
              {CONTACT.address.street}<br />
              {CONTACT.address.neighborhood}, CEP: {CONTACT.address.cep}<br />
              {CONTACT.address.city} — {CONTACT.address.stateAbbr}
            </p>
          </div>
          <div class="flex items-center gap-3">
            <Icon name="lucide:phone" class="h-4 w-4 shrink-0 text-white" />
            <a href={`tel:+${CONTACT.whatsapp}`} class="text-[0.875rem] text-white underline-offset-2 hover:underline">
              {CONTACT.phone}
            </a>
          </div>
          <div class="flex items-center gap-3">
            <Icon name="lucide:mail" class="h-4 w-4 shrink-0 text-white" />
            <a href={`mailto:${CONTACT.email}`} class="text-[0.875rem] text-white underline-offset-2 hover:underline">
              {CONTACT.email}
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-16 flex flex-col items-center justify-between gap-4 border-t border-white/20 pt-8 sm:flex-row">
      <p class="text-[12px] text-white/80">
        &copy; {new Date().getFullYear()} {SITE_TITLE}. Todos os direitos reservados.
      </p>
      <p class="text-[12px] text-white/80">
        Palmas — Tocantins — Brasil
      </p>
    </div>
  </div>
</footer>
